# Shared runtime
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=AI Platform Control Dashboard (Staging)
SESSION_TTL_SECONDS=43200
SESSION_ROTATION_WINDOW_SECONDS=1800
DATABASE_SSL=true

# Dashboard -> control-plane routing
CONTROL_PLANE_API_BASE_URL=https://control-plane-staging.example.com
NEXT_PUBLIC_CONTROL_PLANE_API_BASE_URL=https://control-plane-staging.example.com
CONTROL_PLANE_ALLOWED_ORIGIN=https://dashboard-staging.example.com

# Dashboard / API state paths for non-Cloudflare container runs
AUTH_STATE_FILE=/app/.data/dashboard-auth.json
ADMIN_CATALOG_STATE_FILE=/app/.data/dashboard-admin-catalog.json
CONTROL_PLANE_STATE_FILE=/app/.data/control-plane-state.json

# Infra endpoints
CONTROL_PLANE_API_HOST=0.0.0.0
CONTROL_PLANE_API_PORT=4100
REDIS_URL=redis://redis:6379/0

# Secrets are provided via GitHub environment secrets or wrangler secret put
# SESSION_SECRET=
# CONTROL_PLANE_API_TOKEN=
# DATABASE_URL=
# ADMIN_MFA_TEST_CODE=