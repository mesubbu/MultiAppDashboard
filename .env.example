# Public app metadata used by the dashboard shell.
NEXT_PUBLIC_APP_NAME=AI Platform Control Dashboard

# Dashboard auth/session settings.
SESSION_SECRET=local-dev-session-secret-change-me-1234567890
SESSION_TTL_SECONDS=43200
SESSION_ROTATION_WINDOW_SECONDS=1800
ADMIN_MFA_TEST_CODE=000000

# Postgres backing store shared by the dashboard and control-plane API.
# Leave blank to fall back to local file-backed state for local-only development.
DATABASE_URL=
DATABASE_POOL_MAX=10
DATABASE_RETRY_ATTEMPTS=3
DATABASE_RETRY_BACKOFF_MS=250
DATABASE_SSL=false

# Optional observability integrations for the dashboard observability page.
OBSERVABILITY_GRAFANA_DASHBOARD_URL=
OBSERVABILITY_GRAFANA_OVERVIEW_EMBED_URL=
OBSERVABILITY_GRAFANA_ALERTS_EMBED_URL=
OBSERVABILITY_GRAFANA_SERVICE_URL_TEMPLATE=
OBSERVABILITY_LOKI_SERVICE_URL_TEMPLATE=
OBSERVABILITY_PROMETHEUS_URL=
OBSERVABILITY_PROMETHEUS_API_URL=
OBSERVABILITY_PROMETHEUS_TIMEOUT_MS=3000
OBSERVABILITY_PROMETHEUS_CPU_QUERY=sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=""}[5m])) * 100
OBSERVABILITY_PROMETHEUS_MEMORY_QUERY=max by (container_label_com_docker_compose_service) ((container_memory_working_set_bytes{container_label_com_docker_compose_service!=""} / container_spec_memory_limit_bytes{container_label_com_docker_compose_service!=""}) * 100)
OBSERVABILITY_PROMETHEUS_RESTARTS_QUERY=sum by (container_label_com_docker_compose_service) (changes(container_start_time_seconds{container_label_com_docker_compose_service!=""}[24h]))
OBSERVABILITY_SERVICE_ALERT_THRESHOLDS_JSON={"defaults":{"cpuPercent":{"degraded":75,"critical":90},"memoryPercent":{"degraded":80,"critical":90},"restarts24h":{"degraded":1,"critical":3}},"services":{"agent-runtime":{"cpuPercent":{"degraded":70,"critical":85},"restarts24h":{"degraded":1,"critical":2}}}}

# File-backed fallbacks used when DATABASE_URL is not configured.
AUTH_STATE_FILE=.data/dashboard-auth.json
ADMIN_CATALOG_STATE_FILE=.data/dashboard-admin-catalog.json
CONTROL_PLANE_STATE_FILE=.data/control-plane-state.json

# Dashboard -> control-plane API integration.
NEXT_PUBLIC_CONTROL_PLANE_API_BASE_URL=http://127.0.0.1:4100
CONTROL_PLANE_API_BASE_URL=http://127.0.0.1:4100
CONTROL_PLANE_API_TOKEN=local-control-plane-token
CONTROL_PLANE_API_HOST=0.0.0.0
CONTROL_PLANE_API_PORT=4100
CONTROL_PLANE_ALLOWED_ORIGIN=http://localhost:3000

# Cloudflare / OpenNext deployment settings.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
