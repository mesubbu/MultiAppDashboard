# Shared runtime
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=AI Platform Control Dashboard
SESSION_TTL_SECONDS=43200
SESSION_ROTATION_WINDOW_SECONDS=1800
DATABASE_SSL=true

# Dashboard -> control-plane routing
CONTROL_PLANE_API_BASE_URL=http://control-plane-api:4100
NEXT_PUBLIC_CONTROL_PLANE_API_BASE_URL=https://dashboard.example.com/api/control-plane
CONTROL_PLANE_ALLOWED_ORIGIN=https://dashboard.example.com

# Local persistent paths inside containers
AUTH_STATE_FILE=/app/.data/dashboard-auth.json
ADMIN_CATALOG_STATE_FILE=/app/.data/dashboard-admin-catalog.json
CONTROL_PLANE_STATE_FILE=/app/.data/control-plane-state.json

# Infra endpoints
CONTROL_PLANE_API_HOST=0.0.0.0
CONTROL_PLANE_API_PORT=4100
REDIS_URL=redis://redis:6379/0

# Optional observability integrations for embedded dashboards and deep links.
OBSERVABILITY_GRAFANA_DASHBOARD_URL=https://grafana.example.com/d/platform/platform-health
OBSERVABILITY_GRAFANA_OVERVIEW_EMBED_URL=https://grafana.example.com/d-solo/platform/platform-health?orgId=1&panelId=1&theme=dark
OBSERVABILITY_GRAFANA_ALERTS_EMBED_URL=https://grafana.example.com/d-solo/platform/platform-health?orgId=1&panelId=2&theme=dark
OBSERVABILITY_GRAFANA_SERVICE_URL_TEMPLATE=https://grafana.example.com/d/service-health/service-health?var-service={service}&var-layer={layer}
OBSERVABILITY_LOKI_SERVICE_URL_TEMPLATE=https://grafana.example.com/explore?query={service}&endpoint={endpoint}
OBSERVABILITY_PROMETHEUS_URL=https://prometheus.example.com/graph
OBSERVABILITY_PROMETHEUS_API_URL=https://prometheus.example.com
OBSERVABILITY_PROMETHEUS_TIMEOUT_MS=3000
OBSERVABILITY_PROMETHEUS_CPU_QUERY=sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=""}[5m])) * 100
OBSERVABILITY_PROMETHEUS_MEMORY_QUERY=max by (container_label_com_docker_compose_service) ((container_memory_working_set_bytes{container_label_com_docker_compose_service!=""} / container_spec_memory_limit_bytes{container_label_com_docker_compose_service!=""}) * 100)
OBSERVABILITY_PROMETHEUS_RESTARTS_QUERY=sum by (container_label_com_docker_compose_service) (changes(container_start_time_seconds{container_label_com_docker_compose_service!=""}[24h]))
OBSERVABILITY_SERVICE_ALERT_THRESHOLDS_JSON={"defaults":{"cpuPercent":{"degraded":75,"critical":90},"memoryPercent":{"degraded":80,"critical":90},"restarts24h":{"degraded":1,"critical":3}},"services":{"agent-runtime":{"cpuPercent":{"degraded":70,"critical":85},"restarts24h":{"degraded":1,"critical":2}},"observability-api":{"memoryPercent":{"degraded":70,"critical":85}}}}

# Secrets live in /srv/secrets and are mounted by docker-compose.vps.yml
# /srv/secrets/dashboard_session_secret
# /srv/secrets/control_plane_api_token
# /srv/secrets/platform_database_url
# /srv/secrets/postgres_password